// Lógica JavaScript (Cronómetro + Puntos)
//Este código maneja el tiempo y utiliza el array CATALOGO_ALGORITMOS que definimos antes.

let tiempoInicio;
let intervalo;
let funcionando = false;
let segundosTranscurridos = 0;

// Supongamos que esta variable cambia cuando el usuario elige un ejercicio (1-9)
let idEjercicioActivo = 1; 

function gestionarCronometro() {
    const btn = document.getElementById('btn-control');
    const display = document.getElementById('display-tiempo');
    const resultado = document.getElementById('resultado-final');

    if (!funcionando) {
        // --- INICIAR ---
        funcionando = true;
        btn.innerText = "PARAR Y CALCULAR PUNTOS";
        btn.style.backgroundColor = "#ff4d4d";
        segundosTranscurridos = 0;
        resultado.innerText = "";

        intervalo = setInterval(() => {
            segundosTranscurridos++;
            display.innerText = formatearTiempo(segundosTranscurridos);
        }, 1000);

    } else {
        // --- PARAR ---
        funcionando = false;
        clearInterval(intervalo);
        btn.innerText = "REINTENTAR";
        btn.style.backgroundColor = "#4CAF50";

        // Calcular puntos usando tu fórmula
        const puntos = obtenerPuntosFinales(idEjercicioActivo, segundosTranscurridos);
        const datosEj = CATALOGO_ALGORITMOS.find(e => e.id === idEjercicioActivo);

        resultado.innerHTML = `
            <p>¡Reto Terminado!</p>
            <p>Ejercicio: ${datosEj.enunciado}</p>
            <p>Puntos obtenidos: <span style="font-size: 1.5em;">${puntos}</span></p>
        `;
    }
}

function formatearTiempo(segundos) {
    const mins = Math.floor(segundos / 60);
    const secs = segundos % 60;
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
}

// Reutilizamos la función de puntos que definimos antes
function obtenerPuntosFinales(idEjercicio, segundos) {
    const ej = CATALOGO_ALGORITMOS.find(item => item.id === idEjercicio);
    if (!ej) return 0;

    // Tu fórmula: 240 - (Segundos * Factor)
    let calculo = 240 - (segundos * ej.factor);
    return Math.max(0, Math.round(calculo));
}
